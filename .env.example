# UPAY 独角数卡适配器
# 复制为 .env 后填写实际值: cp .env.example .env

# UPAY 接口地址（例如 https://your-upay.com）
UPAY_BASE_URL=

# 独角数卡通讯密钥（验签用），与独角数卡后台填写的通讯密钥一致；不填则使用 UPAY_API_TOKEN
# GATEWAY_TOKEN=
# UPAY API Token（调 UPAY 接口与签名）
UPAY_API_TOKEN=

# 本适配器对外访问地址，必填（例如 https://adapter.example.com），用于创建订单与回调
ADAPTER_PUBLIC_URL=

# 宿主机暴露端口，默认 3100
PORT=3100
